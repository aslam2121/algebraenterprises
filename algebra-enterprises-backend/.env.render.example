NODE_ENV=production
HOST=0.0.0.0
PORT=10000

# Generate long random values for all Strapi secrets below.
APP_KEYS=replace-with-comma-separated-keys
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# Render Postgres
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=false
DATABASE_CONNECTION_TIMEOUT=60000
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Cloudflare R2 media
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=replace-me
R2_PUBLIC_URL=https://<public-media-host>
R2_ROOT_PATH=
R2_ACL=
R2_FORCE_PATH_STYLE=true
R2_MAX_ATTEMPTS=8
R2_CONNECTION_TIMEOUT_MS=120000
R2_REQUEST_TIMEOUT_MS=600000
R2_SIGNED_URL_EXPIRES=900

# Optional
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://algebraenterprises-frontend.onrender.com
FRONTEND_URL=
PROPERTY_IMAGE_WATERMARK=ALGEBRA ENTERPRISES
