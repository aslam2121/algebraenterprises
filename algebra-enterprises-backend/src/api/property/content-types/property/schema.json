{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Property"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "Description": {
      "type": "blocks"
    },
    "Price": {
      "type": "decimal"
    },
    "Property_Type": {
      "type": "enumeration",
      "enum": [
        "Apartment",
        "Entire Building",
        "Independent House",
        "Duplex",
        "Service Apartment",
        "Farm House"
      ]
    },
    "Listing_Type": {
      "type": "enumeration",
      "enum": [
        "For Rent",
        "For Sale",
        "For Rent and For Sale"
      ]
    },
    "Property_Status": {
      "type": "enumeration",
      "enum": [
        "Live",
        "Rented Out",
        "Sold"
      ]
    },
    "Bedrooms": {
      "type": "integer"
    },
    "Bathrooms": {
      "type": "integer"
    },
    "Area_Sqm": {
      "type": "decimal"
    },
    "Area_sqft": {
      "type": "decimal"
    },
    "Area_Acre": {
      "type": "decimal"
    },
    "Property_Code": {
      "type": "uid"
    },
    "Images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Agent_Phone": {
      "type": "string"
    },
    "Featured_Property": {
      "type": "boolean"
    },
    "Property_Age": {
      "type": "integer"
    },
    "Features": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Air Conditioning",
        "Balcony",
        "Basement",
        "Brand New",
        "Corner Plot",
        "Dining Room",
        "Driveway Parking",
        "Equipped Kitchen",
