NODE_ENV=production

# Public backend URL used by the public site and agent route handlers.
NEXT_PUBLIC_STRAPI_URL=https://your-backend-service.onrender.com

# Public media host used by next/image allowlisting.
R2_PUBLIC_URL=https://your-public-media-host

# Optional: only set this if you still need the raw R2 endpoint allowlisted.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
